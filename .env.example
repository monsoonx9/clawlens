# Redis (Upstash) - Server-only (NO NEXT_PUBLIC_ prefix)
# Get these from your Upstash console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Vault Secret - Server-only encryption key for API keys
# Generate with: openssl rand -base64 32
# Must be at least 32 characters
VAULT_SECRET=your-super-secure-vault-secret-min-32-chars

# =====================================================
# Supabase Configuration (Personal Assistant)
# Get these from your Supabase project: https://app.supabase.com/
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only - DO NOT expose to client (.env.local only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# App URL (Required for Telegram webhooks)
# Set this to your Vercel deployment URL
# =====================================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# =====================================================
# Telegram Bot Configuration (Per-user bots)
# Users provide their own bot tokens - you don't need to set this
# Just ensure NEXT_PUBLIC_APP_URL is set above
# =====================================================
# TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret

# Optional: Rate Limiting Configuration
# MAX_CONCURRENT_API_REQUESTS=5
# MAX_API_REQUESTS_PER_SECOND=10
# MAX_CONCURRENT_SKILLS=5

# =====================================================
# Cron Job Configuration (Background Tasks)
# Used to authenticate cron job endpoints for background notifications
# Generate with: openssl rand -hex 32
# =====================================================
# CRON_SECRET=your-random-cron-secret
